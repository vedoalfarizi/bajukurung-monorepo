# Base URL for the backend API
VITE_API_URL=http://localhost:3000

# Seller WhatsApp number (no leading +, e.g. 60123456789 for Malaysia)
VITE_SELLER_PHONE=60123456789

# Cognito Hosted UI — Seller authentication
VITE_COGNITO_DOMAIN=https://your-domain.auth.ap-southeast-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_client_id
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/seller/callback
